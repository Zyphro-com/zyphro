// api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ---------------------------------------------------------
// EL MOTOR VORTEX (ARCHIVOS Y TEXTO) - Simplificado
// ---------------------------------------------------------

model Vortex {
  id            String   @id @default(cuid())

  // Contenido
  type          String   @default("FILE")
  fileName      String?
  fileSize      BigInt
  mimeType      String?

  // Seguridad xChaCha20
  s3Key         String?  @unique
  textContent   String?

  // Control de Vida
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  maxViews      Int      @default(1)
  downloadCount Int      @default(0)
}
